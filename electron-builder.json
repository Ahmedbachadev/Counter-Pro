{
  "appId": "com.counterpro.pos",
  "productName": "Counter Pro",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "dist/**/*",
    "public/electron.cjs",
    "public/preload.cjs",
    "public/localdb.cjs",
    "public/assets/**/*"
  ],
  "asar": true,
  "asarUnpack": [
    "**/better-sqlite3/**/*"
  ],
  "mac": {
    "category": "public.app-category.business",
    "target": "dmg"
  },
  "win": {
    "target": "nsis",
    "icon": "public/assets/icon.png"
  },
  "linux": {
    "target": "AppImage",
    "category": "Office"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}