{
  "name": "khata-book",
  "private": true,
  "author": "Swatify Labs",
  "description": "Khata book is an app to automate your management",
  "version": "0.0.0",
  "type": "module",
  "main": "public/electron.cjs",
  "homepage": "./",
  "scripts": {
    "dev:db": "node scripts/build-db.js",
    "dev": "npm run dev:db && vite",
    "build": "npm run dev:db && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env ELECTRON_DEV=true electron .\"",
    "electron-pack": "npm run build && npx electron-builder",
    "dist": "npm run build && npx electron-builder --publish=never"
  },
  "dependencies": {
    "@react-pdf/font": "^4.0.3",
    "@supabase/supabase-js": "^2.110.0",
    "@tanstack/react-virtual": "^3.14.5",
    "better-sqlite3": "^12.11.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.42.2",
    "html2canvas": "^1.4.1",
    "i18next": "^25.5.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "jspdf": "^3.0.3",
    "lucide-react": "^0.344.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.7.3",
    "react-router-dom": "^7.9.1",
    "wait-on": "^9.0.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "cross-env": "^10.1.0",
    "electron": "^38.2.1",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
